TRISMEGISTUS_HOST=127.0.0.1
TRISMEGISTUS_PORT=8898

# Hermes / NemoClaw OpenAI-compatible gateway.
# Leave these unset or local until the real stack is running.
HERMES_BASE_URL=http://127.0.0.1:8642/v1/chat/completions
HERMES_MODEL=hermes-agent
HERMES_API_KEY=

NEMOCLAW_DASHBOARD_URL=http://127.0.0.1:18789
NEMOCLAW_OPENAI_BASE_URL=http://127.0.0.1:8642/v1
NEMOCLAW_API_KEY=

# Nous / Hermes Provider. Keep real values only in local .env.
NOUS_API_KEY=
NEMOCLAW_PROVIDER_KEY=

# Stripe Skills. Draft mode never creates live charges.
STRIPE_ENABLED=draft
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_ALLOW_LIVE_CHARGES=0

# Apple Mail bridge. Drafts are allowed; live sends require explicit approval.
TRIS_ALLOW_MAC_MAIL_SEND=0

# Messaging channels. Keep real bot tokens only in local .env.
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Optional live scout query source.
TRISMEGISTUS_LIVE_SCAN=1

# Browser autonomy stack.
# Playwright is the browser control engine. CDP is the host-browser bridge.
TRIS_BROWSER_CDP_URL=http://127.0.0.1:9222

# Firecrawl local sidecar for fast source/RAG ingestion.
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=local_development_key

# WebArena / BrowserGym self-hosted domains.
# Set these only after the official WebArena services are running.
WA_SHOPPING=
WA_SHOPPING_ADMIN=
WA_REDDIT=
WA_GITLAB=
WA_WIKIPEDIA=
WA_MAP=
WA_HOMEPAGE=
WA_FULL_RESET=
